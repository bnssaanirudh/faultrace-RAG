{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/runs/[id]/trace",
      "regex": "^/runs/([^/]+?)/trace(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/runs/(?<nxtPid>[^/]+?)/trace(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/annotations",
      "regex": "^/annotations(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/annotations(?:/)?$"
    },
    {
      "page": "/certificates",
      "regex": "^/certificates(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/certificates(?:/)?$"
    },
    {
      "page": "/datasets",
      "regex": "^/datasets(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/datasets(?:/)?$"
    },
    {
      "page": "/experiments",
      "regex": "^/experiments(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/experiments(?:/)?$"
    },
    {
      "page": "/leaderboard",
      "regex": "^/leaderboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/leaderboard(?:/)?$"
    },
    {
      "page": "/oracle",
      "regex": "^/oracle(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/oracle(?:/)?$"
    },
    {
      "page": "/queries",
      "regex": "^/queries(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/queries(?:/)?$"
    },
    {
      "page": "/reports",
      "regex": "^/reports(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/reports(?:/)?$"
    },
    {
      "page": "/run-lab",
      "regex": "^/run\\-lab(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/run\\-lab(?:/)?$"
    },
    {
      "page": "/runs",
      "regex": "^/runs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/runs(?:/)?$"
    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings(?:/)?$"
    },
    {
      "page": "/worlds",
      "regex": "^/worlds(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/worlds(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:8000/api/:path*",
      "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ]
}